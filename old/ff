import QtQuick
import QtQuick.Layouts
import Quickshell
import Quickshell.Wayland
import "Widgets"
import "services"

PanelWindow {
    property string bgColor: colors.bgColor
    property string bgPrimary: colors.bgPrimary
    property string bgPrimaryDark: colors.bgPrimaryDark
    property string bgSecondary: colors.bgSecondary
    property string bgSecondaryDark: colors.bgSecondaryDark


    implicitHeight: 44
    color: "transparent"

    ColorLoader {
        id: colors
    }

    anchors {
        top: true
        left: true
        right: true
    }

    Dock {
    }

    Rectangle {
        // Center section - notch

        anchors.fill: parent
        radius: 15
        color: bgColor
        anchors.verticalCenter: parent.verticalCenter
        anchors.leftMargin: 4
        anchors.rightMargin: 4
        anchors.topMargin: 2
        anchors.bottomMargin: 0

        // Left section with right-rounded corners
        Item {
            width: 120
            height: 44
            anchors.left: parent.left
            anchors.verticalCenter: parent.verticalCenter
            anchors.leftMargin: -0

            Row {
                spacing: 8
                anchors.left: parent.left
                anchors.verticalCenter: parent.verticalCenter
                anchors.leftMargin: 10

                Test {
                }

                ColorPicker {
                }

                ScreenShot {
                }

            }

        }

        // Right section with left-rounded corners
        Item {
            width: 140
            height: 44
            anchors.right: parent.right
            anchors.verticalCenter: parent.verticalCenter
            anchors.rightMargin: -0

            Row {
                spacing: 8
                anchors.right: parent.right
                anchors.verticalCenter: parent.verticalCenter
                anchors.rightMargin: 10

                Battery {
                    anchors.verticalCenter: parent.verticalCenter
                }

                Battery2 {
                    anchors.verticalCenter: parent.verticalCenter
                }

                Win {
                }

            }

        }

    }

    Item {
        anchors.fill: parent

        Notch {
            anchors.horizontalCenter: parent.horizontalCenter
        }

    }

}
